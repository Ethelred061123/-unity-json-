  m_text: "\t\u4E09\u664B\u5927\u5730\uFF0C\u94C1\u8840\u94F8\u9B42\uFF1B\u519B\u5DE5\u85AA\u706B\uFF0C\u4EE3\u4EE3\u76F8\u4F20\u3002\u56DE\u6EAF\u767E\u5E74\uFF0C1898\u5E74\u7684\u5C71\u897F\u673A\u5668\u5C40\u7834\u571F\u800C\u751F\uFF0C\u5728\u6E05\u672B\u7684\u98CE\u96E8\u98D8\u6447\u4E2D\uFF0C\u64AD\u4E0B\u4E86\u5C71\u897F\u8FD1\u4EE3\u519B\u5DE5\u7684\u7B2C\u4E00\u9897\u79CD\u5B50\uFF0C\u7B80\u964B\u7684\u5382\u623F\u91CC\uFF0C\u5DE5\u5320\u4EEC\u4EE5\u94C1\u9524\u4E0E\u7089\u706B\uFF0C\u5F00\u542F\u4E86\u201C\u664B\u9020\u201D\u5175\u5DE5\u7684\u8E52\u8DDA\u8D77\u6B65\u3002\u5C81\u6708\u6D41\u8F6C\uFF0C\u592A\u539F\u5175\u5DE5\u5382\u5728\u6C11\u56FD\u5E74\u95F4\u8D70\u5411\u9F0E\u76DB\uFF0C\u673A\u5E8A\u8F70\u9E23\u95F4\uFF0C\u664B\u9020\u706B\u70AE\u3001\u67AA\u68B0\u5E94\u8FD0\u800C\u751F\uFF0C\u6210\u4E3A\u5F53\u65F6\u4E2D\u56FD\u519B\u5DE5\u9886\u57DF\u7684\u91CD\u8981\u529B\u91CF\uFF0C\u89C1\u8BC1\u7740\u6C11\u65CF\u5DE5\u4E1A\u7684\u6323\u624E\u4E0E\u5D1B\u8D77\u3002\u70FD\u706B\u6297\u6218\u65F6\u671F\uFF0C\u9EC4\u5D16\u6D1E\u5175\u5DE5\u5382\u9690\u4E8E\u592A\u884C\u6DF1\u5904\uFF0C\u5148\u8F88\u4EEC\u514B\u670D\u7F3A\u8BBE\u5907\u3001\u5C11\u539F\u6599\u7684\u8270\u96BE\uFF0C\u767D\u624B\u8D77\u5BB6\u3001\u81EA\u529B\u66F4\u751F\uFF0C\u5728\u67AA\u6797\u5F39\u96E8\u4E2D\u751F\u4EA7\u6B66\u5668\uFF0C\u7528\u94C1\u4E0E\u8840\u94F8\u5C31\u4E86\u6C11\u65CF\u6551\u4EA1\u7684\u810A\u6881\uFF0C\u4E66\u5199\u4E86\u201C\u6CA1\u6709\u67AA\u6CA1\u6709\u70AE\u6211\u4EEC\u81EA\u5DF1\u9020\u201D\u7684\u82F1\u96C4\u53F2\u8BD7\u3002\u4E71\u4E16\u80B2\u82F1\u624D\uFF0C\u592A\u884C\u5DE5\u4E1A\u5B66\u6821\u3001\u534E\u5317\u7B2C\u4E94\u5DE5\u4E1A\u5B66\u6821\u5E94\u8FD0\u800C\u751F\uFF0C\u5728\u6218\u706B\u4E2D\u4F20\u9053\u6388\u4E1A\uFF0C\u4E3A\u5175\u5DE5\u4E8B\u4E1A\u64AD\u6492\u4EBA\u624D\u706B\u79CD\uFF0C\u8BA9\u5175\u5DE5\u6280\u827A\u4E0E\u7231\u56FD\u60C5\u6000\u4EE3\u4EE3\u76F8\u4F20\u3002\u767E\u5E74\u98CE\u96E8\u517C\u7A0B\uFF0C\u4ECE\u6E05\u672B\u7684\u840C\u82BD\u521D\u63A2\u5230\u6297\u6218\u7684\u70FD\u706B\u575A\u5B88\uFF0C\u4ECE\u4EBA\u624D\u57F9\u80B2\u7684\u85AA\u706B\u76F8\u4F20\u5230\u73B0\u4EE3\u519B\u5DE5\u7684\u8FED\u4EE3\u5347\u7EA7\uFF0C\u5C71\u897F\u519B\u5DE5\u7684\u6BCF\u4E00\u6B65\u524D\u884C\uFF0C\u90FD\u954C\u523B\u7740\u5BB6\u56FD\u60C5\u6000\u4E0E\u594B\u6597\u8DB3\u8FF9\uFF0C\u6BCF\u4E00\u6BB5\u8FC7\u5F80\uFF0C\u90FD\u85CF\u7740\u5148\u8F88\u4EEC\u7684\u575A\u5B88\u4E0E\u62C5\u5F53\uFF0C\u90A3\u4E9B\u6591\u9A73\u7684\u673A\u5E8A\u3001\u6CDB\u9EC4\u7684\u7167\u7247\uFF0C\u90FD\u5728\u9759\u9759\u8BC9\u8BF4\u7740\u4E09\u664B\u5927\u5730\u4E0A\uFF0C\u4E00\u6BB5\u6BB5\u70ED\u8840\u6CB8\u817E\u7684\u5175\u5DE5\u4F20\u5947\u3002"
