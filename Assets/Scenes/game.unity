  m_text: "19 \u4E16\u7EAA\u672B\uFF0C\u6D0B\u52A1\u8FD0\u52A8\u5E2D\u5377\u5168\u56FD\uFF0C\u4E3A\u5B9E\u73B0\u81EA\u5F3A\u6C42\u5BCC\u3001\u9769\u65B0\u5730\u65B9\u519B\u5907\uFF0C\u65F6\u4EFB\u5C71\u897F\u5DE1\u629A\u7684\u80E1\u8058\u4E4B\u4E8E
    1898 \u5E74\uFF08\u5149\u7EEA\u4E8C\u5341\u56DB\u5E74\uFF09\u6B63\u5F0F\u594F\u8BF7\u5149\u7EEA\u7687\u5E1D\u521B\u529E\u5C71\u897F\u673A\u5668\u5C40\uFF0C\u83B7\u6279\u540E\u4EE5
    48000 \u4E24\u5E93\u94F6\u4E3A\u542F\u52A8\u8D44\u91D1\uFF0C\u5728\u592A\u539F\u57CE\u5317\u95E8\u5916\u9009\u5740\u5EFA\u5382\uFF0C\u5360\u5730
    38 \u4EA9\uFF0C\u8FD9\u662F\u5C71\u897F\u8FD1\u4EE3\u519B\u5DE5\u4E0E\u673A\u68B0\u5DE5\u4E1A\u7684\u6B63\u5F0F\u5F00\u7AEF\u3002\n\u521D\u521B\u9636\u6BB5\u7684\u5C71\u897F\u673A\u5668\u5C40\uFF0C\u6446\u8131\u4E86\u4F20\u7EDF\u624B\u5DE5\u4F5C\u574A\u7684\u751F\u4EA7\u6A21\u5F0F\uFF0C\u4ECE\u82F1\u56FD\u798F\u516C\u53F8\u5F15\u8FDB\u4E86\u6765\u590D\u7EBF\u673A\u5E8A\u3001\u84B8\u6C7D\u52A8\u529B\u8BBE\u5907\u7B49\u8FD1\u4EE3\u5DE5\u4E1A\u8BBE\u65BD\uFF0C\u4E3B\u8981\u5F00\u5C55\u67AA\u68B0\u4FEE\u7406\u3001\u7B80\u6613\u5175\u5668\u914D\u4EF6\u5236\u4F5C\u7B49\u4E1A\u52A1\uFF0C\u662F\u5C71\u897F\u5883\u5185\u9996\u4E2A\u91C7\u7528\u673A\u5668\u751F\u4EA7\u7684\u519B\u5DE5\u673A\u6784\u3002\u4F5C\u4E3A\u5C71\u897F\u8FD1\u4EE3\u5DE5\u4E1A\u7684\u8D77\u70B9\uFF0C\u5B83\u6253\u7834\u4E86\u5F53\u5730\u4F20\u7EDF\u624B\u5DE5\u4E1A\u7684\u5C40\u9650\uFF0C\u5B8C\u6210\u4E86\u4ECE\u51B7\u5175\u5668\u914D\u5957\u5230\u8FD1\u4EE3\u70ED\u5175\u5668\u751F\u4EA7\u7684\u521D\u6B65\u8FC7\u6E21\uFF0C\u4E5F\u4E3A\u540E\u7EED\u592A\u539F\u5175\u5DE5\u5382\u7684\u89C4\u6A21\u5316\u53D1\u5C55\u57CB\u4E0B\u4E86\u4F0F\u7B14\u3002\n\u503C\u5F97\u4E00\u63D0\u7684\u662F\uFF0C\u5C71\u897F\u673A\u5668\u5C40\u5F00\u521B\u4E86\u5C71\u897F\u4EE5\u84B8\u6C7D\u4E3A\u52A8\u529B\u3001\u91D1\u5C5E\u5207\u524A\u673A\u5E8A\u4E3A\u624B\u6BB5\u7684\u5175\u5668\u751F\u4EA7\u6A21\u5F0F\uFF0C\u6807\u5FD7\u7740\u5C71\u897F\u5DE5\u4E1A\u6587\u660E\u7684\u89C9\u9192\u3002\u5386\u7ECF\u767E\u5E74\u53D8\u8FC1\uFF0C\u5C71\u897F\u673A\u5668\u5C40\u7684\u6838\u5FC3\u65E7\u5740\u81F3\u4ECA\u4ECD\u5B8C\u6574\u4FDD\u5B58\uFF0C\u6210\u4E3A
